# ── Database ──
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/finance

# ── Auth Mode ──
# "better-auth" — Full login/register with Better Auth (default)
# "simple"      — No login needed; single default user (ideal for personal/family use)
AUTH_MODE=simple
NEXT_PUBLIC_AUTH_MODE=simple

# ── Better Auth (required only when AUTH_MODE=better-auth) ──
# Secret key for signing sessions (generate with: openssl rand -hex 32)
BETTER_AUTH_SECRET=change-me-to-a-random-secret-at-least-32-chars
BETTER_AUTH_URL=http://localhost:3000

# ── Public URL (used by auth client) ──
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Simple Auth Options (optional, only used when AUTH_MODE=simple) ──
# DEFAULT_USER_NAME=User
# DEFAULT_USER_EMAIL=user@localhost
# Password gate — set a password to protect your instance (leave empty to skip)
# SIMPLE_AUTH_PASSWORD=your-password-here

# ── Registration Restriction (optional, only used when AUTH_MODE=better-auth) ──
# Comma-separated list of allowed emails, or "DISABLED" to block all signups
# ALLOWED_EMAILS=you@example.com,partner@example.com